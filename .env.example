# Lazy Podcast Mate — secrets and endpoints.
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# --- LLM (script rewriting) ---
# Supported providers: openai_compatible | anthropic | domestic
LLM_PROVIDER=
LLM_API_KEY=
# Base URL — used by openai_compatible (e.g. https://api.openai.com/v1)
# and by domestic providers that expose an OpenAI-compatible endpoint.
LLM_BASE_URL=
# Model ID (e.g. gpt-4o, claude-3-5-sonnet-20241022, qwen-plus)
LLM_MODEL=

# --- TTS (voice synthesis) ---
# Supported providers: volcano | azure | cosyvoice
TTS_PROVIDER=
TTS_API_KEY=
# Used by Azure TTS (e.g. eastus). Unused by other providers — leave blank.
TTS_REGION=
# Used by Volcano Engine (app_id/cluster), Azure (voice name), CosyVoice (base URL).
# See config.yaml for voice selection; these env vars hold only auth/endpoint values.
TTS_APP_ID=
TTS_CLUSTER=
TTS_BASE_URL=

# --- Optional overrides ---
# Path to a non-default config.yaml. If unset, `./config.yaml` is used.
# LPM_CONFIG_PATH=/absolute/path/to/config.yaml
